{
  "name": "cs-demo-manager",
  "version": "3.19.3",
  "description": "Companion application for your Counter-Strike demos.",
  "keywords": [
    "CS",
    "CS2",
    "CS:GO",
    "CSGO",
    "Counter-Strike",
    "electron",
    "react"
  ],
  "homepage": "https://cs-demo-manager.com",
  "bugs": {
    "url": "https://github.com/akiver/cs-demo-manager/issues"
  },
  "license": "MIT",
  "author": {
    "name": "AkiVer",
    "email": "ys.renaud@gmail.com"
  },
  "repository": "https://github.com/akiver/cs-demo-manager",
  "main": "main.js",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "compile": "tsc --noEmit",
    "deadcode": "knip",
    "dev": "node ./scripts/develop.mjs",
    "dev:cli": "node ./scripts/develop-cli.mjs",
    "electron": "electron ./out/main.js",
    "format": "vp fmt",
    "i18n:extract": "lingui extract --config ./lingui.config.ts --clean --overwrite && lingui extract --config ./src/electron-main/lingui.config.ts --clean --overwrite",
    "i18n:patch-zh-cn": "node ./scripts/patch-zh-cn-from-installed-app.mjs",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "package": "electron-builder --config electron-builder.config.mjs",
    "package:dir": "vp run package --dir",
    "postinstall": "electron-builder install-app-deps && node ./scripts/postinstall.mjs && node ./scripts/build-linter-rules.mjs",
    "prepare": "vp config",
    "t": "vp run test",
    "tw": "vp run test:watch",
    "test": "vp test",
    "test:watch": "vp test --watch"
  },
  "devDependencies": {
    "@akiver/boiler-writter": "1.7.0",
